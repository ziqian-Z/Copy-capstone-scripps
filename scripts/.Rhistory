# Make a working copy
working_data <- cal_data %>%
mutate(across(where(is.character), as.factor))
# Only use rows that are *not* NA for this variable
non_missing_rows <- which(!is.na(working_data$temperature_depth_105))
# Randomly mask 5% of those values for evaluation
set.seed(123)
eval_idx <- sample(non_missing_rows, size = round(0.05 * length(non_missing_rows)))
# Store true values before masking
true_vals <- working_data$temperature_depth_105[eval_idx]
# Create dataset with artificial missing values
eval_data <- working_data
eval_data$temperature_depth_105[eval_idx] <- NA
# Mean imputation
mean_val <- mean(eval_data$temperature_depth_105, na.rm = TRUE)
mean_imputed <- eval_data
mean_imputed$temperature_depth_105[is.na(mean_imputed$temperature_depth_105)] <- mean_val
# KNN imputation (VIM::kNN adds a suffix "_imp")
knn_imputed <- kNN(eval_data, variable = "temperature_depth_105", k = 5)
knn_vals <- knn_imputed$temperature_depth_105[eval_idx]
# Median imputation
median_val <- median(eval_data$temperature_depth_105, na.rm = TRUE)
median_imputed <- eval_data
median_imputed$temperature_depth_105[is.na(median_imputed$temperature_depth_105)] <- median_val
median_vals <- median_imputed$temperature_depth_105[eval_idx]
# Mode imputation
get_mode <- function(x) {
ux <- na.omit(unique(x))
ux[which.max(tabulate(match(x, ux)))]
}
mode_val <- get_mode(eval_data$temperature_depth_105)
mode_imputed <- eval_data
mode_imputed$temperature_depth_105[is.na(mode_imputed$temperature_depth_105)] <- mode_val
mode_vals <- mode_imputed$temperature_depth_105[eval_idx]
# RMSE comparison
rmse_table <- tibble::tibble(
Method = c("Mean", "KNN", "Mode", "Median"),
RMSE = c(
rmse(true_vals, mean_vals),
rmse(true_vals, knn_vals),
rmse(true_vals, mode_vals),
rmse(true_vals, median_vals)
)
)
# Load required libraries
library(dplyr)
library(VIM)
library(Metrics)
library(tibble)
# Make a working copy
working_data <- cal_data %>%
mutate(across(where(is.character), as.factor))
# Only use rows that are *not* NA for this variable
non_missing_rows <- which(!is.na(working_data$temperature_depth_105))
# Randomly mask 5% of those values for evaluation
set.seed(123)
eval_idx <- sample(non_missing_rows, size = round(0.05 * length(non_missing_rows)))
# Store true values before masking
true_vals <- working_data$temperature_depth_105[eval_idx]
# Create dataset with artificial missing values
eval_data <- working_data
eval_data$temperature_depth_105[eval_idx] <- NA
### Mean Imputation
mean_val <- mean(eval_data$temperature_depth_105, na.rm = TRUE)
mean_imputed <- eval_data
mean_imputed$temperature_depth_105[is.na(mean_imputed$temperature_depth_105)] <- mean_val
mean_vals <- mean_imputed$temperature_depth_105[eval_idx]  # <-- added this line
### KNN Imputation (VIM adds *_imp columns)
knn_imputed <- kNN(eval_data, variable = "temperature_depth_105", k = 5)
knn_vals <- knn_imputed$temperature_depth_105[eval_idx]
### Median Imputation
median_val <- median(eval_data$temperature_depth_105, na.rm = TRUE)
median_imputed <- eval_data
median_imputed$temperature_depth_105[is.na(median_imputed$temperature_depth_105)] <- median_val
median_vals <- median_imputed$temperature_depth_105[eval_idx]
### Mode Imputation
get_mode <- function(x) {
ux <- na.omit(unique(x))
ux[which.max(tabulate(match(x, ux)))]
}
mode_val <- get_mode(eval_data$temperature_depth_105)
mode_imputed <- eval_data
mode_imputed$temperature_depth_105[is.na(mode_imputed$temperature_depth_105)] <- mode_val
mode_vals <- mode_imputed$temperature_depth_105[eval_idx]
### RMSE Comparison Table
rmse_table <- tibble::tibble(
Method = c("Mean", "KNN", "Mode", "Median"),
RMSE = c(
rmse(true_vals, mean_vals),
rmse(true_vals, knn_vals),
rmse(true_vals, mode_vals),
rmse(true_vals, median_vals)
)
)
print(rmse_table)
# Define the full model with all predictors
full_model <- lm(fin_resp ~ est_depth_std + temperature_depth_105_std + temperature_depth_55_std + temperature_depth_280_std + salinity_depth_55_std + salinity_depth_105_std + magnitude_depth_55_std + magnitude_depth_105_std + theta_depth_55_std + theta_depth_105_std + larvae_count_std,
data = train_data)
# Perform forward stepwise selection using the step() function
best_stepwise_model <- step(current_model,
scope = list(lower = current_model, upper = full_model), direction = "forward")
# Define the initial model with only the intercept
current_model <- lm(fin_resp ~ 1, data = train_data)
# Perform forward stepwise selection using the step() function
best_stepwise_model <- step(current_model,
scope = list(lower = current_model, upper = full_model), direction = "forward")
acf(cal_data$fin_resp)
acf(cal_data$fin_resp, na.rm = T)
