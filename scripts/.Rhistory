# Split data into training and testing sets (80% train)
set.seed(123)
split <- initial_split(cal_data, prop = 0.8)
train_data <- training(split)
test_data  <- testing(split)
# Step 1: Extract numeric columns from train and test sets
train_numeric <- train_data %>% select(where(is.numeric))
test_numeric  <- test_data %>% select(where(is.numeric))
# Step 2: Fit the preProcess model with knnImpute on training data
pre_proc <- preProcess(train_numeric, method = "knnImpute")
# Step 3: Apply KNN imputation to train and test sets
train_imputed_numeric <- predict(pre_proc, newdata = train_numeric)
test_imputed_numeric  <- predict(pre_proc, newdata = test_numeric)
# Step 4: Combine imputed numeric columns with the original non-numeric columns
train_data_imputed <- bind_cols(
train_data %>% select(!where(is.numeric)),
train_imputed_numeric
)
test_data_imputed <- bind_cols(
test_data %>% select(!where(is.numeric)),
test_imputed_numeric
)
